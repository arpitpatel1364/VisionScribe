# ── Django ────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ────────────────────────────────────────
DB_NAME=vision_rag
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Ollama ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_VLM_MODEL=qwen2.5vl   # vision-language model

# ── ChromaDB ──────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_TEXT=vision_rag_text
CHROMA_COLLECTION_IMAGE=vision_rag_image

# ── Embeddings ────────────────────────────────────────
TEXT_EMBED_MODEL=BAAI/bge-m3
IMAGE_EMBED_MODEL=openai/clip-vit-base-patch32

# ── YOLO ──────────────────────────────────────────────
YOLO_MODEL_PATH=./models/yolo_doc_layout.pt
YOLO_CONFIDENCE=0.35

# ── Ingestion ─────────────────────────────────────────
INGESTION_WORKERS=4
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_IMAGE_SIDE=1024

# ── Retrieval ─────────────────────────────────────────
TOP_K_DENSE=10
TOP_K_SPARSE=10
TOP_K_FINAL=5
HYBRID_ALPHA=0.6            # 0=pure BM25, 1=pure dense
